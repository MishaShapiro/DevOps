server {
   listen 80;
   server_name shop.local;

   return 301 https://$host$request_uri;
}


server {
   listen 443 ssl;

   server_name shop.local;

   ssl_certificate /etc/nginx/ssl/nginx.crt;
   ssl_certificate_key /etc/nginx/ssl/nginx.key;

   location / {
       proxy_pass http://127.0.0.1:8002;
   }

   location /images/ {
       alias /var/www/shop_images/;
   }
}
