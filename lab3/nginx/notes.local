server {
   listen 80;
   server_name notes.local;

   return 301 https://$host$request_uri;
}


server {
   listen 443 ssl;

   server_name notes.local;

   ssl_certificate /etc/nginx/ssl/nginx.crt;
   ssl_certificate_key /etc/nginx/ssl/nginx.key;

   location / {
       proxy_pass http://127.0.0.1:8001;
   }

   location /static/ {
       alias /var/www/notes_static/;
   }
}
